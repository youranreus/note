# ---- Web ----
VITE_API_BASE_URL=${VITE_API_BASE_URL}
# Browser redirect target for the SSO authorize page.
VITE_SSO_URL=${VITE_SSO_URL}
VITE_SSO_ID=${VITE_SSO_ID}
VITE_SSO_REDIRECT=${VITE_SSO_REDIRECT}

# ---- API ----
NODE_ENV=development
PORT=3001
API_ORIGIN=http://localhost:3001
WEB_ORIGIN=http://localhost:5173

# Existing external MySQL instance
DATABASE_URL=mysql://root:password@127.0.0.1:3306/note

# Cookie / session
COOKIE_NAME=sid
COOKIE_SECURE=false
SESSION_TTL_SECONDS=604800

# SSO integration
# SSO_URL is the backend API endpoint used by the server for code exchange and userinfo.
# Real OAuth callbacks return a `code` query parameter (not `ticket`).
# Mock login only for codes like mock:1001:Demo%20User when SSO_MOCK_ENABLED=true.
# During local development, keep mock enabled if no real SSO env is available.
SSO_URL=https://sf.imouto.tech
# If token/userinfo POST gets 405 on SSO_URL (CDN/nginx GET-only), set API origin that accepts POST (ask IdP).
# SSO_API_BASE_URL=https://your-idp-api-host.example
SSO_ID=note-web
SSO_SECRET=replace-me
SSO_REDIRECT=http://localhost:5173/auth/callback
SSO_MOCK_ENABLED=true
SSO_MOCK_TICKET_PREFIX=mock:
