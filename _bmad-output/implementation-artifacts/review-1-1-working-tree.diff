--- /dev/null
+++ b/scripts/boot.mjs
@@ -0,0 +1,25 @@
+import { spawn } from 'node:child_process'
+
+function run(command, args) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(command, args, {
+      cwd: process.cwd(),
+      stdio: 'inherit',
+      shell: process.platform === 'win32'
+    })
+
+    child.on('exit', (code) => {
+      if (code === 0) {
+        resolve()
+        return
+      }
+
+      reject(new Error(`${command} ${args.join(' ')} exited with code ${code ?? 'unknown'}`))
+    })
+
+    child.on('error', reject)
+  })
+}
+
+await run('pnpm', ['sync:env'])
+console.log('Workspace bootstrapped. Use pnpm dev, pnpm build, or pnpm test.')

diff --git a/scripts/sync-env.mjs b/scripts/sync-env.mjs
new file mode 100644
index 0000000..f36c406
--- /dev/null
+++ b/scripts/sync-env.mjs
@@ -0,0 +1,135 @@
+import { access, mkdir, readFile, writeFile } from 'node:fs/promises'
+import path from 'node:path'
+import { fileURLToPath } from 'node:url'
+
+const __filename = fileURLToPath(import.meta.url)
+const __dirname = path.dirname(__filename)
+const rootDir = path.resolve(__dirname, '..')
+
+function parseEnvFile(content) {
+  const entries = {}
+
+  for (const rawLine of content.split(/\r?\n/u)) {
+    const line = rawLine.trim()
+
+    if (!line || line.startsWith('#')) {
+      continue
+    }
+
+    const separatorIndex = line.indexOf('=')
+
+    if (separatorIndex === -1) {
+      continue
+    }
+
+    const key = line.slice(0, separatorIndex).trim()
+    let value = line.slice(separatorIndex + 1).trim()
+
+    if (
+      (value.startsWith('"') && value.endsWith('"')) ||
+      (value.startsWith("'") && value.endsWith("'"))
+    ) {
+      value = value.slice(1, -1)
+    }
+
+    entries[key] = value
+  }
+
+  return entries
+}
+
+async function readOptionalFile(filePath) {
+  try {
+    await access(filePath)
+    return await readFile(filePath, 'utf8')
+  } catch {
+    return ''
+  }
+}
+
+function ensureAuthCallback(urlString, fallbackBase) {
+  const fallback = new URL('/auth/callback', fallbackBase).toString()
+
+  if (!urlString) {
+    return fallback
+  }
+
+  try {
+    const url = new URL(urlString)
+    url.pathname = '/auth/callback'
+    url.search = ''
+    url.hash = ''
+    return url.toString()
+  } catch {
+    return fallback
+  }
+}
+
+function toEnvFile(entries) {
+  return [
+    '# Generated by scripts/sync-env.mjs',
+    ...Object.entries(entries).map(([key, value]) => `${key}=${value}`),
+    ''
+  ].join('\n')
+}
+
+async function main() {
+  const exampleEnvPath = path.join(rootDir, '.env.example')
+  const localEnvPath = path.join(rootDir, '.env')
+
+  const exampleEnv = parseEnvFile(await readOptionalFile(exampleEnvPath))
+  const localEnv = parseEnvFile(await readOptionalFile(localEnvPath))
+  const mergedEnv = { ...exampleEnv, ...localEnv }
+
+  const webOrigin = mergedEnv.WEB_ORIGIN ?? 'http://localhost:5173'
+  const apiOrigin = mergedEnv.API_ORIGIN ?? 'http://localhost:3001'
+  const callbackUrl = ensureAuthCallback(
+    mergedEnv.SSO_REDIRECT ?? mergedEnv.VITE_SSO_REDIRECT,
+    webOrigin
+  )
+
+  const normalizedEnv = {
+    NODE_ENV: mergedEnv.NODE_ENV ?? 'development',
+    PORT: mergedEnv.PORT ?? '3001',
+    API_ORIGIN: apiOrigin,
+    WEB_ORIGIN: webOrigin,
+    DATABASE_URL: mergedEnv.DATABASE_URL ?? '',
+    COOKIE_NAME: mergedEnv.COOKIE_NAME ?? 'sid',
+    COOKIE_SECURE: mergedEnv.COOKIE_SECURE ?? 'false',
+    SESSION_TTL_SECONDS: mergedEnv.SESSION_TTL_SECONDS ?? '604800',
+    SSO_URL: mergedEnv.SSO_URL ?? mergedEnv.VITE_SSO_URL ?? '',
+    SSO_ID: mergedEnv.SSO_ID ?? mergedEnv.VITE_SSO_ID ?? '',
+    SSO_SECRET: mergedEnv.SSO_SECRET ?? '',
+    SSO_REDIRECT: callbackUrl,
+    SSO_MOCK_ENABLED: mergedEnv.SSO_MOCK_ENABLED ?? 'true',
+    SSO_MOCK_TICKET_PREFIX: mergedEnv.SSO_MOCK_TICKET_PREFIX ?? 'mock:',
+    VITE_API_BASE_URL: mergedEnv.VITE_API_BASE_URL ?? apiOrigin,
+    VITE_SSO_URL: mergedEnv.VITE_SSO_URL ?? mergedEnv.SSO_URL ?? '',
+    VITE_SSO_ID: mergedEnv.VITE_SSO_ID ?? mergedEnv.SSO_ID ?? '',
+    VITE_SSO_REDIRECT: ensureAuthCallback(
+      mergedEnv.VITE_SSO_REDIRECT ?? mergedEnv.SSO_REDIRECT,
+      webOrigin
+    )
+  }
+
+  const webEnv = Object.fromEntries(
+    Object.entries(normalizedEnv).filter(([key]) => key.startsWith('VITE_'))
+  )
+
+  const apiEnv = Object.fromEntries(
+    Object.entries(normalizedEnv).filter(([key]) => !key.startsWith('VITE_'))
+  )
+
+  const webEnvPath = path.join(rootDir, 'apps/web/.env.local')
+  const apiEnvPath = path.join(rootDir, 'apps/api/.env')
+
+  await mkdir(path.dirname(webEnvPath), { recursive: true })
+  await mkdir(path.dirname(apiEnvPath), { recursive: true })
+
+  await writeFile(webEnvPath, toEnvFile(webEnv), 'utf8')
+  await writeFile(apiEnvPath, toEnvFile(apiEnv), 'utf8')
+
+  console.log(`Synced environment to ${path.relative(rootDir, webEnvPath)} and ${path.relative(rootDir, apiEnvPath)}`)
+}
+
+await main()
