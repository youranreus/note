{
  "name": "@note/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm -w prepare:types && pnpm -w sync:env",
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:init": "prisma db push --schema prisma/schema.prisma && prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@note/shared-types": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@reus-able/sso-utils": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
