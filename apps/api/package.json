{
  "name": "@note/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "db:init": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "prisma:smoke": "tsx scripts/prisma-smoke.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^5.22.0",
    "@reus-able/sso-utils": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
