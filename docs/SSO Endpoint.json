  "tags": [],
  "paths": {
    "/oauth/authorize": {
      "post": {
        "summary": "授权端点",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "client_id": {
                    "type": "string",
                    "title": "应用ID"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "title": "回调地址"
                  },
                  "state": {
                    "type": "string",
                    "title": "状态码",
                    "description": "随机字符串"
                  }
                },
                "required": [
                  "client_id",
                  "redirect_uri",
                  "state"
                ]
              },
              "example": {
                "client_id": "96241be6-4521-4a57-9013-70bc23685cb2",
                "redirect_uri": "https://paper.imouto.tech/login",
                "state": "asasasa"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "msg": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "access_token": {
                          "type": "string"
                        },
                        "state": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "access_token",
                        "state"
                      ]
                    }
                  },
                  "required": [
                    "code",
                    "msg",
                    "data"
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
