          },
          "avatar": {
            "type": "string",
            "title": "头像",
            "nullable": true
          }
        },
        "required": [
          "nickname",
          "created_at",
          "role",
          "id",
          "updated_at",
          "email",
          "avatar"
        ]
      },
      "Restful": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "nullable": true,
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "array"
              },
              {
                "type": "object"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "required": [
          "code",
          "msg",
          "data"
        ]
      }
    },
    "responses": {},
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "servers": [],
  "security": []
