  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "nickname": {
            "type": "string",
            "title": "用户名",
            "description": "纯英文"
          },
          "email": {
            "type": "string",
