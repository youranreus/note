        "summary": "令牌端点",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "description": "应用ID",
            "required": true,
            "example": "96241be6-4521-4a57-9013-70bc23685cb2",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_secret",
            "in": "query",
            "description": "应用秘钥",
            "required": true,
            "example": "bbViODVoECHswFXE",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code",
            "in": "query",
            "description": "access_token",
            "required": true,
            "example": "",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "description": "回调地址",
            "required": true,
            "example": "https://paper.imouto.tech/login",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "msg": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "access_token": {
                          "type": "string"
                        },
                        "token_type": {
                          "type": "string"
                        },
                        "scope": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "access_token",
                        "token_type",
                        "scope"
                      ]
                    }
                  },
                  "required": [
                    "code",
                    "msg",
                    "data"
                  ]
                }
              }
            }
          }
        },
        "security": []
      }
