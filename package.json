{
  "name": "note-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "boot": "node scripts/boot.mjs",
    "db:init": "pnpm sync:env && pnpm --filter @note/api db:init",
    "start:api:prod": "pnpm sync:env && pnpm --filter @note/api prisma:generate && pnpm --filter @note/api build && pnpm --filter @note/api start",
    "sync:env": "node scripts/sync-env.mjs",
    "prepare:types": "pnpm --filter @note/shared-types build",
    "predev": "pnpm prepare:types && pnpm sync:env",
    "predev:web": "pnpm prepare:types && pnpm sync:env",
    "predev:api": "pnpm prepare:types && pnpm sync:env",
    "prebuild": "pnpm prepare:types && pnpm sync:env",
    "pretest": "pnpm prepare:types && pnpm sync:env",
    "dev": "concurrently -n types,web,api -c magenta,cyan,green \"pnpm --filter @note/shared-types dev\" \"pnpm --filter @note/web dev\" \"pnpm --filter @note/api dev\"",
    "dev:types": "pnpm --filter @note/shared-types dev",
    "dev:web": "pnpm --filter @note/web dev",
    "dev:api": "pnpm --filter @note/api dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "pnpm@10.7.0"
}
